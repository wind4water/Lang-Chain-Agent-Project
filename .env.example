# ========================================
# OpenAI API配置
# ========================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o-mini

# SSL 证书验证配置
# true: 启用 SSL 证书验证（默认，推荐生产环境）
# false: 禁用 SSL 证书验证（仅用于开发/测试环境，或连接自签名证书 API）
# 注意：禁用 SSL 验证会降低安全性，仅在内网或可信环境中使用
SSL_VERIFY=true

# ========================================
# 飞书机器人配置（可选）
# ========================================
# 是否启用飞书机器人
# true: 启用飞书 WebSocket 长连接机器人
# false: 禁用（默认）
FEISHU_ENABLED=false

# 飞书应用凭证（在 https://open.feishu.cn/app 创建自建应用后获取）
# 需要开启机器人能力和消息事件订阅
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SSL 验证配置（默认启用）
# true: 启用 SSL 证书验证（推荐，安全）
# false: 禁用 SSL 证书验证（连接自签名证书 API 时使用，有安全风险）
FEISHU_SSL_VERIFY=true

# 流式推送字符阈值（默认 20）
# 每积累 N 个字符就更新一次飞书卡片
FEISHU_STREAM_CHUNK_SIZE=20

# 流式推送间隔（毫秒，默认 300）
# 即使字符数未达到阈值，也至少每 N 毫秒更新一次
FEISHU_STREAM_INTERVAL_MS=300

# 卡片消息最大长度（默认 2800）
# 飞书卡片 markdown 元素长度限制约 3000 字符
FEISHU_MAX_CARD_CONTENT=2800

# Skill 配置（可选）
# 指定飞书机器人使用的 skill，控制响应策略和格式
# feishu_rag_first: 默认 skill，优先 RAG + 智能工具调用
# resp_style: 定制响应风格（开头"总，你好，" + 结尾激励语）
FEISHU_SKILL_ID=feishu_rag_first

# ==================== 飞书使用说明 ====================
# 1. 在 https://open.feishu.cn/app 创建自建应用
# 2. 开启「机器人」能力
# 3. 订阅「接收消息」事件（im.message.receive_v1）
# 4. 获取 App ID 和 App Secret
# 5. 设置 FEISHU_ENABLED=true 并填写凭证
# 6. 重启服务
# 7. 在飞书群聊或私聊中 @机器人 即可对话
#
# 特点：
# - WebSocket 长连接模式，无需公网 IP
# - 支持私聊和群聊（群聊需 @机器人）
# - 使用卡片消息流式更新，体验流畅
# - 每个用户/群组独立会话上下文

# ========================================
# 工具系统配置（⭐ 新功能）
# ========================================
# 是否启用工具调用功能
# true: Agent 可以自动调用工具（推荐）
# false: 纯对话模式，不调用工具
ENABLE_TOOLS=true

# ========================================
# 上下文压缩策略（可选）
# ========================================
# 压缩策略选择: none | sliding_window | token_limit | summary
# - none: 不压缩（默认，适合短对话）
# - sliding_window: 滑动窗口（推荐，简单高效）
# - token_limit: Token计数（精确控制token使用）
# - summary: 智能摘要（最先进，需额外LLM调用）
CONTEXT_COMPRESSION_STRATEGY=none

# 滑动窗口策略配置（当CONTEXT_COMPRESSION_STRATEGY=sliding_window时生效）
# 保留最近N轮对话，1轮=2条消息（用户+助手）
# 示例：10轮 = 20条消息 ≈ 5000-10000 tokens
COMPRESSION_WINDOW_SIZE=10

# Token限制策略配置（当CONTEXT_COMPRESSION_STRATEGY=token_limit时生效）
# 最大token数（留出空间给LLM输出）
# 注意：这是粗略估计，实际token计数可能有差异
# GPT-4o-mini上下文: 128k tokens，建议设置4000-8000
COMPRESSION_MAX_TOKENS=4000

# 智能摘要策略配置（当CONTEXT_COMPRESSION_STRATEGY=summary时生效）
# 超过N轮对话后开始生成摘要
COMPRESSION_SUMMARY_THRESHOLD=20

# 摘要使用的模型（建议用便宜的模型）
SUMMARY_MODEL_NAME=gpt-4o-mini

# ==================== 策略选择建议 ====================
# 场景1: 简单问答、客服 → sliding_window (窗口5-10轮)
# 场景2: 代码助手、技术支持 → token_limit (4000-6000 tokens)
# 场景3: 长期咨询、项目管理 → summary (阈值15-20轮)
# 场景4: 测试开发阶段 → none (不压缩，观察实际情况)

# ==================== 工具系统说明 ====================
# 当 ENABLE_TOOLS=true 时，Agent 可以使用以下工具：
# 1. get_current_date_tool - 获取当前日期和时间
# 2. get_current_timestamp - 获取Unix时间戳
# 3. get_weekday - 获取今天是星期几
#
# 查看所有可用工具: GET http://localhost:8000/tools
# 详细文档: 查看 TOOL_CALLING.md

# ========================================
# Langfuse 监控配置（可选）
# ========================================
# 是否启用 Langfuse 追踪和监控
# true: 启用云端监控和完整 trace 追踪
# false: 禁用（默认，不影响现有功能）
LANGFUSE_ENABLED=false

# Langfuse API 密钥
# 注册地址: https://cloud.langfuse.com
# 在 Settings -> API Keys 中获取
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here

# Langfuse 服务端点
# 云端服务: https://cloud.langfuse.com（默认）
# 自托管服务: https://your-langfuse-instance.com
LANGFUSE_HOST=https://cloud.langfuse.com

# 追踪采样率（可选，0.0-1.0）
# 1.0: 追踪所有请求（默认，适合开发和测试）
# 0.5: 追踪 50% 的请求（生产环境节省成本）
# 0.1: 追踪 10% 的请求（高流量场景）
LANGFUSE_SAMPLE_RATE=1.0

# 是否追踪工具调用的详细信息（可选）
# true: 追踪工具的输入输出（默认，推荐）
# false: 仅追踪工具名称（减少数据量）
LANGFUSE_TRACE_TOOL_DETAILS=true

# Langfuse 批量上传配置（可选，一般无需修改）
# 批量上传的时间间隔（秒），默认 1 秒
LANGFUSE_FLUSH_INTERVAL=1

# 单次批量上传的最大事件数，默认 15
LANGFUSE_FLUSH_AT=15

# ==================== Langfuse 功能说明 ====================
# Langfuse 提供的监控能力：
# 1. 完整的 trace 追踪（LLM → 工具 → LLM 调用链）
# 2. 性能监控（延迟、Token 消耗、成本分析）
# 3. 按 session_id 分组的会话级追踪
# 4. 实时监控面板和可视化图表
# 5. 工具调用成功率和性能分析
#
# 启用步骤：
# 1. 注册 Langfuse 账号: https://cloud.langfuse.com
# 2. 创建项目，获取 PUBLIC_KEY 和 SECRET_KEY
# 3. 设置 LANGFUSE_ENABLED=true
# 4. 重启服务：python app/main.py
# 5. 发送测试请求，查看 Langfuse 面板
#
# 注意事项：
# - Langfuse 与现有 SQLite token 统计共存，互不影响
# - 配置错误或连接失败不会影响对话功能（优雅降级）
# - 生产环境建议设置 LANGFUSE_SAMPLE_RATE=0.5 节省成本
# - 数据默认保留 30 天（免费版），企业版可自定义
# - ⚠️ 已知问题：Langfuse 回调可能输出一些内部错误信息（如 'NoneType' 或 'run not found'）
#   这些错误是由于 LangGraph 与 Langfuse 的兼容性问题导致的，不影响实际功能
#   已通过安全包装器和错误处理进行了优化，可以忽略这些错误信息
#
# 查看监控数据：
# - Web 面板: https://cloud.langfuse.com
# - 健康检查: GET http://localhost:8000/health
# - 详细文档: 查看 doc/langfuse-integration-plan.md

# ========================================
# ChromaDB 遥测配置
# ========================================
# 是否启用 ChromaDB 匿名遥测
# true: 启用（默认）
# false: 禁用（推荐，避免版本兼容性问题）
ANONYMIZED_TELEMETRY=False

# ========================================
# RAG 系统配置（⭐ 知识库问答）
# ========================================
# 是否启用 RAG（检索增强生成）功能
# true: 启用知识库问答（推荐）
# false: 禁用 RAG 功能（默认）
RAG_ENABLED=false

# 文档存储路径
# RAG 系统从此目录读取文档构建知识库
# 支持格式: .txt, .md, .pdf
RAG_DOCUMENTS_PATH=./data/documents

# 向量数据库存储路径
# Chroma 向量数据库的持久化目录
RAG_CHROMA_PATH=./data/chroma

# 向量数据库集合名称
# 同一数据库中可以有多个集合（类似表）
RAG_COLLECTION_NAME=langchain_docs

# 嵌入模型
# OpenAI 嵌入模型，用于文档和查询的向量化
# 可选: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
EMBEDDING_MODEL=text-embedding-3-small

# 检索配置
# 检索时返回的最相关文档数量
RAG_TOP_K=4

# 检索类型
# similarity: 相似度检索（默认）
# mmr: 最大边际相关性（平衡相关性和多样性）
# similarity_score_threshold: 基于相似度阈值的检索
RAG_SEARCH_TYPE=similarity

# 相似度阈值（当 RAG_SEARCH_TYPE=similarity_score_threshold 时生效）
# 范围 0.0-1.0，越高表示要求越相似
RAG_SCORE_THRESHOLD=0.7

# 文本分割配置
# 文本块大小（字符数）
CHUNK_SIZE=1000

# 文本块重叠大小（字符数）
# 保持上下文连贯性
CHUNK_OVERLAP=200

# 是否在启动时自动重建知识库
# true: 每次启动时重新加载文档并重建索引（推荐开发阶段）
# false: 使用现有索引，不重建（推荐生产环境）
RAG_REBUILD_ON_STARTUP=true

# ==================== RAG 使用说明 ====================
# RAG 系统提供基于本地文档的知识库问答能力
#
# 快速开始：
# 1. 创建文档目录: mkdir -p data/documents
# 2. 放入文档: 将 .txt, .md, .pdf 文件放入 data/documents/
# 3. 启用 RAG: 设置 RAG_ENABLED=true
# 4. 启动服务: python app/main.py
# 5. 查询知识库: POST http://localhost:8000/rag/query
#
# API 端点：
# - POST /rag/query - 知识库问答（返回答案和来源）
# - POST /rag/rebuild - 手动重建知识库
# - GET /rag/stats - RAG 系统统计信息
#
# 文档组织建议：
# - 按主题分子目录: data/documents/product/, data/documents/tech/
# - 使用清晰的文件名: product-guide-2024.pdf, api-reference.md
# - 保持文档更新: 定期清理过期文档
#
# 性能优化：
# - 开发阶段: RAG_REBUILD_ON_STARTUP=true（便于快速迭代）
# - 生产环境: RAG_REBUILD_ON_STARTUP=false（使用 /rag/rebuild 手动更新）
# - 大量文档: 增加 CHUNK_SIZE 到 1500-2000
# - 精确匹配: 调高 RAG_SCORE_THRESHOLD 到 0.8-0.9
#
# 注意事项：
# - 文档变更后需要重建索引（重启或调用 /rag/rebuild）
# - 向量数据库文件较大，建议加入 .gitignore
# - 初次构建可能较慢，取决于文档数量和大小
# - RAG 查询需要消耗 embedding API 调用（计费）
#
# 详细文档: 查看 docs/guides/rag-quick-start.md
