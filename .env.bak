# ========================================
# OpenAI API配置
# ========================================
# 智谱AI配置
OPENAI_API_KEY=6c6a956be1b149f3bfe528481608fab4.Rc59K2Q6TCfKnbGs
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
MODEL_NAME=glm-4-flash

# ========================================
# 工具系统配置
# ========================================
# 是否启用工具调用功能
ENABLE_TOOLS=true

# ========================================
# 上下文压缩策略
# ========================================
# 压缩策略选择: none | sliding_window | token_limit | summary
CONTEXT_COMPRESSION_STRATEGY=sliding_window

# 滑动窗口策略配置
# 保留最近N轮对话，1轮=2条消息（用户+助手）
# 示例：10轮 = 20条消息 ≈ 5000-10000 tokens
COMPRESSION_WINDOW_SIZE=10


# Langfuse
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-e099c2f4-9c65-4ee1-9d45-cf8abf1a5ca7
LANGFUSE_SECRET_KEY=sk-lf-661ad876-bae2-4542-a913-99248c1e5e3e

# ========================================
# ChromaDB 遥测配置
# ========================================
# 禁用 ChromaDB 匿名遥测（避免 posthog 版本兼容性问题）
ANONYMIZED_TELEMETRY=False

# ========================================
# RAG 配置
# ========================================
RAG_ENABLED=true
RAG_REBUILD_ON_STARTUP=false  # 使用智能同步（增量更新）而非全量重建

# RAG 路径配置（统一使用项目根目录下的 data/）
CHROMA_PATH=./data/vectordb/chroma
RAG_DOCUMENTS_PATH=./data/documents

# 嵌入模型配置（使用智谱AI的Embedding-3）
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSION=1024

# Hybrid 检索
RAG_RETRIEVAL_MODE=hybrid
RAG_HYBRID_KEYWORD_K=8

# ES关键词搜索
RAG_KEYWORD_BACKEND=es
ES_ENABLED=true
ES_HOSTS=http://127.0.0.1:9200
ES_INDEX_NAME=rag_keyword_chunks

# 飞书机器人
FEISHU_ENABLED=true
FEISHU_APP_ID=cli_a947bfad28b9dcd5
FEISHU_APP_SECRET=LQnL9nzmbPllS9alhrvBof2DDpBskI5v
FEISHU_SSL_VERIFY=false
# 流式推送字符阈值（默认 20）
FEISHU_STREAM_CHUNK_SIZE=20
# 流式推送间隔（毫秒，默认 300）
FEISHU_STREAM_INTERVAL_MS=300
# 卡片消息最大长度（默认 2800）
FEISHU_MAX_CARD_CONTENT=2800
# Skill 配置（resp_style: 定制响应风格，feishu_rag_first: RAG优先）
FEISHU_SKILL_ID=resp_style

# ReAct模式
ENABLE_TASK_PLANNER=true
TASK_PLANNER_TRIGGER=auto
TASK_PLANNER_MAX_TASKS=5

# EMBEDDING 配置
# -----远程-----
#EMBEDDING_TYPE=remote
#EMBEDDING_MODEL=text-embedding-3-small
# -----本地-----
EMBEDDING_TYPE=local
EMBEDDING_MODEL=bge-base-zh-v1.5