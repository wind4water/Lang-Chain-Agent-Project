# ========================================
# OpenAI API配置
# ========================================
# 智谱AI配置
OPENAI_API_KEY=6c6a956be1b149f3bfe528481608fab4.Rc59K2Q6TCfKnbGs
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
MODEL_NAME=glm-4.5-air

# ========================================
# 工具系统配置
# ========================================
# 是否启用工具调用功能
ENABLE_TOOLS=true

# ========================================
# 上下文压缩策略
# ========================================
# 压缩策略选择: none | sliding_window | token_limit | summary
CONTEXT_COMPRESSION_STRATEGY=sliding_window

# 滑动窗口策略配置
# 保留最近N轮对话，1轮=2条消息（用户+助手）
# 示例：10轮 = 20条消息 ≈ 5000-10000 tokens
COMPRESSION_WINDOW_SIZE=10


# Langfuse
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-e099c2f4-9c65-4ee1-9d45-cf8abf1a5ca7
LANGFUSE_SECRET_KEY=sk-lf-661ad876-bae2-4542-a913-99248c1e5e3e

# ========================================
# ChromaDB 遥测配置
# ========================================
# 禁用 ChromaDB 匿名遥测（避免 posthog 版本兼容性问题）
ANONYMIZED_TELEMETRY=False

# ========================================
# RAG 配置
# ========================================
RAG_ENABLED=true
RAG_REBUILD_ON_STARTUP=false  # 使用智能同步（增量更新）而非全量重建

# RAG 路径配置（统一使用项目根目录下的 data/）
CHROMA_PATH=./data/vectordb/chroma
RAG_DOCUMENTS_PATH=./data/documents,./data/projects

# 嵌入模型配置（使用智谱AI的Embedding-3）
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIMENSION=1024

# Hybrid 检索
RAG_RETRIEVAL_MODE=hybrid
RAG_HYBRID_KEYWORD_K=8

# ES关键词搜索
RAG_KEYWORD_BACKEND=es
ES_ENABLED=true
ES_HOSTS=http://127.0.0.1:9200
ES_INDEX_NAME=rag_keyword_chunks

# 飞书机器人
FEISHU_ENABLED=true
FEISHU_APP_ID=cli_a947bfad28b9dcd5
FEISHU_APP_SECRET=LQnL9nzmbPllS9alhrvBof2DDpBskI5v
FEISHU_SSL_VERIFY=false
# 流式推送字符阈值（默认 20）
FEISHU_STREAM_CHUNK_SIZE=20
# 流式推送间隔（毫秒，默认 300）
FEISHU_STREAM_INTERVAL_MS=300
# 卡片消息最大长度（默认 2800）
FEISHU_MAX_CARD_CONTENT=2800
# Skill 配置（resp_style: 定制响应风格，feishu_rag_first: RAG优先）
FEISHU_SKILL_ID=resp_style

# ReAct模式
ENABLE_TASK_PLANNER=true
TASK_PLANNER_TRIGGER=auto
TASK_PLANNER_MAX_TASKS=5

# EMBEDDING 配置
# -----远程-----
#EMBEDDING_TYPE=remote
#EMBEDDING_MODEL=text-embedding-3-small
# -----本地-----
EMBEDDING_TYPE=local
EMBEDDING_MODEL=bge-base-zh-v1.5

HF_ENDPOINT=https://hf-mirror.com
# ========================================
# RAG 检索优化配置
# ========================================
# 检索返回的文档数量（默认4）
RAG_TOP_K=6
# 搜索类型: similarity | mmr | similarity_score_threshold
RAG_SEARCH_TYPE=mmr
# 相似度阈值（默认0.5）
RAG_SCORE_THRESHOLD=0.35

# ========================================
# RAG 文本分割配置
# ========================================
# 文本块大小（默认1000）
CHUNK_SIZE=800
# 文本块重叠大小（默认200）
CHUNK_OVERLAP=150

# ========================================
# ES 配置
# ========================================
# HTTPS证书验证（内网可禁用）
ES_VERIFY_CERTS=false

# ========================================
# HNSW 向量索引配置
# ========================================
# 距离度量: cosine | l2 | ip
HNSW_SPACE=cosine
# HNSW 最大连接数（默认16）
HNSW_M=24
# HNSW 搜索候选列表（默认100）
HNSW_EF_SEARCH=200

# ========================================
# 代码专用嵌入模型配置（双模型方案）
# ========================================
# 是否启用代码专用嵌入模型（需要额外下载模型）
CODE_EMBEDDING_ENABLED=true
# 代码嵌入模型（CodeBERT）
# 代码专用嵌入模型（使用兼容的模型）
CODE_EMBEDDING_MODEL=microsoft/codebert-base
# 代码嵌入维度（CodeBERT 是 768）
CODE_EMBEDDING_DIMENSION=768
# 代码向量集合名称
CODE_COLLECTION_NAME=code_collection

# ========================================
# 多模型配置（JSON格式）- 单行版本
# 支持为不同路径配置不同的嵌入模型
# ========================================
# 示例：{"path": "./data/documents", "model_type": "bge", "model_name": "BAAI/bge-base-zh-v1.5", "dimension": 768}
# 示例：{"path": "./data/projects", "model_type": "codebert", "model_name": "microsoft/codebert-base", "dimension": 768}
MULTI_MODEL_CONFIG={"configs":[{"path":"./data/documents","model_type":"bge","model_name":"BAAI/bge-base-zh-v1.5","dimension":768},{"path":"./data/projects","model_type":"codebert","model_name":"microsoft/codebert-base","dimension":768}]}

# 多模型检索权重配置
DOC_MODEL_WEIGHT=0.5
CODE_MODEL_WEIGHT=0.5
